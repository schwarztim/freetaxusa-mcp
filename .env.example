# FreeTaxUSA MCP Configuration
# No secrets in this file -- credentials are provided per-call via tool inputs,
# or brokered by Hermes (see below).

# --- Hermes auth broker (authoritative auth path when set) ---
# When HERMES_URL + HERMES_CLIENT_TOKEN are set, Hermes performs the FreeTaxUSA
# login on the host and hands this server a fresh cookie session. The
# `authenticate` tool then needs NO email/password. If Hermes is configured but
# the broker is unreachable, authentication FAILS LOUDLY (it does not silently
# fall back to the embedded browser login) unless FREETAXUSA_LEGACY_AUTH=true.
# NOTE: this only works once the operator registers freetaxusa cookie-session
# credentials with Hermes; the code is Hermes-capable, runtime success depends
# on that setup step.
# HERMES_URL=http://127.0.0.1:9876
# HERMES_CLIENT_TOKEN=<bearer token from ~/.hermes/client.token>
# HERMES_SERVICE=freetaxusa          # service name registered with Hermes (default: freetaxusa)
# HERMES_SCHEME=cookie-session       # credential scheme to request (default: cookie-session)

# Opt back into the embedded Playwright login even when Hermes is configured.
# Default (unset) = Hermes outage fails loudly. Set true to fall back to the
# in-process browser login (and supply email/password to the authenticate tool).
# FREETAXUSA_LEGACY_AUTH=true

# Browser profile directory (default: ~/.freetaxusa-mcp/browser-profile/)
# FREETAXUSA_USER_DATA_DIR=~/.freetaxusa-mcp/browser-profile/

# Headless mode (default: true, set to false for debugging)
# FREETAXUSA_HEADLESS=false

# Tax year (default: 2025)
# FREETAXUSA_TAX_YEAR=2025

# Enable integration tests (requires valid credentials)
# FREETAXUSA_INTEGRATION=true
